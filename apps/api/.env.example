TZ=UTC
PORT=3333
HOST=localhost
LOG_LEVEL=info
APP_KEY=
NODE_ENV=development
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=root
DB_PASSWORD=root
DB_DATABASE=app

# CORS: через запятую разрешённые Origin (браузер), напр. https://vervel.ru,https://www.vervel.ru
# Для VK Mini App добавьте: https://vk.com,https://m.vk.com (и при необходимости https://web.vk.me)
# Пусто — любой Origin (удобно для dev; в проде задайте явный список).
CORS_ALLOWED_ORIGINS=

# AI Workout Recognition (Yandex Cloud)
# Docs: https://console.yandex.cloud/iam/service-accounts
# Roles needed: ai.languageModels.user + ai.vision.user
FEATURE_AI_WORKOUT=false
YANDEX_CLOUD_API_KEY=
YANDEX_FOLDER_ID=
# OCR model: "page" = 0.13 rub/req, "handwritten" = 1.52 rub/req
YANDEX_OCR_MODEL=page
# Чат и дефолтный callGpt без override: yandexgpt-lite | yandexgpt-5-lite | aliceai-llm | …
# Старые id yandexgpt / yandexgpt-lite в коде дополняются /latest; новые (yandexgpt-5.1 и т.д.) — как в консоли.
YANDEX_GPT_MODEL=yandexgpt-lite
# Парсинг тренировок + ИИ «связи с эталонами»: сильнее модель = лучше рассуждения, см. галерею Foundation Models
# Примеры id: yandexgpt | yandexgpt-5.1 | yandexgpt-5-pro | aliceai-llm | deepseek-v32 | qwen3-235b-a22b-fp8
YANDEX_GPT_PARSE_MODEL=yandexgpt

# AI pricing (rubles)
AI_COST_GENERATE=10
AI_COST_RECOGNIZE=9
AI_COST_PARSE_NOTES=10
# Платная подсказка ИИ: связи силового журнала с эталонами (руб./запрос)
AI_COST_SUGGEST_STANDARD_LINKS=8
# Макс. несвязанных упражнений в одном таком запросе (1–200)
AI_STANDARD_LINK_SUGGEST_MAX_CANDIDATES=60
AI_WELCOME_BONUS=50
# Chat — token-based billing: actual_cost = (input_tokens/1000)*INPUT_RATE + (output_tokens/1000)*OUTPUT_RATE, then × MARKUP
# Minimum charge per message regardless of token count
AI_CHAT_INPUT_RATE=0.20
AI_CHAT_OUTPUT_RATE=0.40
AI_CHAT_MARKUP=5
AI_CHAT_MIN_CHARGE=0.50

# OAuth — Яндекс ID (https://oauth.yandex.ru → Мои приложения)
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=https://api.vervel.ru/oauth/yandex/callback

# OAuth — VK (https://vk.com/apps → Настройки)
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URI=https://api.vervel.ru/oauth/vk/callback

# VK Mini Apps — защищённый ключ из настроек приложения (https://dev.vk.com → мини-приложение)
# VK_MINI_APP_ID — опционально: сверка vk_app_id из параметров запуска
VK_MINI_APP_SECRET=
# VK_MINI_APP_ID=54455065
# Для мини-приложения в iframe (Origin vk.com): cookie с SameSite=None (обязательно HTTPS у API)
# AUTH_COOKIE_SAME_SITE=none

# LiveKit видеозвонки (https://livekit.io)
# Для локальной разработки — LiveKit поднят в Docker на localhost:7880
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_HOST=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret000000000000000000000000
# Для прода:
# LIVEKIT_URL=wss://livekit.vervel.ru
# LIVEKIT_API_KEY=<prod-key>
# LIVEKIT_API_SECRET=<prod-secret>

# Web Push Notifications (VAPID)
# Генерация: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:nazar9505@yandex.ru

# ЮКасса — приём платежей (https://yookassa.ru → Настройки → Ключи API)
# Используйте тестовые ключи для разработки (Тестовый магазин в личном кабинете)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Base URL приложения — для return_url после оплаты (без trailing slash)
APP_URL=http://localhost:5173
# "true" — отключить проверку IP-адреса webhook (нужно для локальной разработки)
YOOKASSA_SKIP_IP_CHECK=true

# KLIPY — поиск GIF в чатах (как и GIPHY раньше: только процесс API, тот же файл что APP_KEY)
# Docker: volume ./apps/api:/app — нужен ключ в этом файле на хосте (apps/api/.env), не только в корне репозитория.
KLIPY_API_KEY=
KLIPY_API_BASE=https://api.klipy.com/api/v1