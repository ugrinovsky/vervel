VITE_API_URL=http://localhost:3333
# Нужен для прокси VK ID (POST …/vkid-sdk-config-proxy), иначе OneTap падает на CORS id.vk.ru.

# Прод: канонический origin API, напр. https://api.vervel.ru

# Публичный URL страницы логина для VK ID SDK — должен совпадать с «доверенным redirect URL» в ЛК VK
# посимвольно (https vs http, www, путь: часто именно …/login, а не только домен).
# Не задано → берётся текущий origin + pathname (на странице /login это будет …/login).
# VITE_APP_URL=https://vervel.ru/login

# Встроенный VK Mini App: авто-логин по launch params. Выключить веб без мини-приложения:
# VITE_ENABLE_VK_MINI_APP=false

# VK ID SDK — числовой app id из https://vk.com/apps?act=manage (может совпадать с мини-приложением).
VITE_VK_APP_ID=54455065

# Яндекс ID (Suggest); redirect в ЛК: {origin}/suggest/token — см. YandexIdButton
VITE_YANDEX_CLIENT_ID=your_yandex_client_id
# Если yastatic.net режется: положите копию sdk в public/ и укажите, напр. /ya-passport-sdk.js
# VITE_YANDEX_SDK_URL=/ya-passport-sdk.js
